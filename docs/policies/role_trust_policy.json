{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowIAMUserAssume",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::285051607148:user/tofu-deploy"
      },
      "Action": "sts:AssumeRole"
    },
    {
      "Sid": "AllowGitHubOIDC",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::285051607148:oidc-provider/token.actions.githubusercontent.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringLike": {
          "token.actions.githubusercontent.com:sub": "repo:tengzl33t/lum-task:*"
        },
        "ForAllValues:StringEquals": {
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
          "token.actions.githubusercontent.com:iss": "https://token.actions.githubusercontent.com"
        }
      }
    }
  ]
}